# =========================
# FRONTEND (Next.js & Node)
# =========================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
# ENVIRONMENT VARIABLES
# =========================
# Keep API keys and secrets safe!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env*
backend/.env*

# =========================
# BACKEND (Python & FastAPI)
# =========================
backend/__pycache__/
*.py[cod]
*$py.class
backend/.pytest_cache/
backend/venv/
backend/env/
backend/.venv/
backend/package-lock.json
pip-log.txt
pip-delete-this-directory.txt

# =========================
# AI & GEOSPATIAL DATA
